# CupOracle website monorepo — .gitignore

# Dependencies (任何包下的 node_modules)
**/node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz

# Build artifacts (任何包产生的)
/.next/
**/.next/
/.vercel/
**/.vercel/
/out/
**/out/
/build/
**/build/
/dist/
**/dist/

# TypeScript
*.tsbuildinfo
**/*.tsbuildinfo
next-env.d.ts
**/next-env.d.ts

# Environment files
.env
.env*.local
.env.production

# Misc
.DS_Store
*.pem
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Playwright MCP browser artifacts (design 参考截图)
/.playwright-mcp/

# Design screenshots (开发时的视觉参考图，跟构建无关)
/screenshots/

# Cloudflare wrangler
.wrangler/

# Python（如果以后 admin 也纳入 monorepo）
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.coverage
*.egg-info/