{
  "name": "cuporacle-web",
  "version": "0.1.0",
  "private": true,
  "description": "CupOracle monorepo — 2026 World Cup AI prediction website (Next.js + service)",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@cuporacle/website",
    "dev:service": "npm run dev --workspace=@cuporacle/service",
    "build:web": "npm run build --workspace=@cuporacle/website",
    "pages:build": "npm run pages:build --workspace=@cuporacle/website",
    "pages:dev": "npm run pages:dev --workspace=@cuporacle/website",
    "lint:web": "npm run lint --workspace=@cuporacle/website",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}