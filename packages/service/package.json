{
  "name": "@cuporacle/service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CupOracle 后端 API — Cloudflare Workers + Hono, TypeScript",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "typecheck": "tsc --noEmit",
    "sync": "node scripts/sync.mjs",
    "sync:dry": "node scripts/sync.mjs --dry-run",
    "rag:stats": "tsx migrations/seed-rag-corpora.ts --stats-only",
    "rag:seed:local": "tsx migrations/seed-rag-corpora.ts --write-sqlite=./out/rag-test.sqlite --write-vectors",
    "rag:seed:emit": "tsx migrations/seed-rag-corpora.ts --emit-sql=./out/rag-seed.sql --emit-vectors=./out/rag-vectors.jsonl",
    "rag:init:d1": "wrangler d1 execute DB --local --file=migrations/0005_rag_init.sql"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "@types/web-push": "^3.6.4",
    "better-sqlite3": "^12.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "wrangler": "^3.114.17"
  },
  "keywords": [
    "world-cup",
    "ai-prediction",
    "cloudflare-workers",
    "hono"
  ]
}
